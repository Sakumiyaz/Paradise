{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-workflow-risk-v1.json",
  "title": "EDEN Runtime Workflow Risk",
  "type": "object",
  "required": ["schema", "artifact", "authority", "summary", "escalations"],
  "properties": {
    "schema": { "const": "eden-runtime-workflow-risk-v1" },
    "artifact": { "const": "runtime_workflow_risk" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "summary": {
      "type": "object",
      "required": ["effective_risk", "events", "state_mutations", "requires_supervision"],
      "properties": {
        "effective_risk": { "enum": ["low", "medium", "high"] },
        "events": { "type": "integer", "minimum": 0 },
        "state_mutations": { "type": "integer", "minimum": 0 },
        "requires_supervision": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "escalations": { "type": "array" }
  },
  "additionalProperties": true
}
