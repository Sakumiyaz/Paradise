{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-70b-dataset-manifest-v1.json",
  "title": "EDEN 70B Dataset Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "dataset_ready", "splits", "module_coverage"],
  "properties": {
    "schema": {"const": "eden.modular_70b.dataset_manifest.v1"},
    "artifact": {"const": "eden_70b_dataset_manifest"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "dataset_ready": {"type": "boolean"},
    "module_coverage": {"type": "array", "minItems": 6}
  }
}
