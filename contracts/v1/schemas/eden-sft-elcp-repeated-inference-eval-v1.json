{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-sft-elcp-repeated-inference-eval-v1.json",
  "title": "EDEN SFT ELCP Repeated Inference Eval",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "packet_count", "all_packets_require_verification"],
  "properties": {
    "schema": {"const": "eden.sft_elcp.repeated_inference_eval.v1"},
    "artifact": {"const": "eden_sft_elcp_repeated_inference_eval"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "packet_count": {"type": "integer", "minimum": 0},
    "all_packets_require_verification": {"type": "boolean"}
  }
}
