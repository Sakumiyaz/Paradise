{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-circuit-breakers-v1.json",
  "title": "EDEN Runtime Circuit Breakers",
  "type": "object",
  "required": ["schema", "artifact", "authority", "summary", "breakers"],
  "properties": {
    "schema": { "const": "eden-runtime-circuit-breakers-v1" },
    "artifact": { "const": "runtime_circuit_breakers" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "summary": {
      "type": "object",
      "required": ["active_breakers", "total_breakers", "runtime_mode"],
      "properties": {
        "active_breakers": { "type": "integer", "minimum": 0 },
        "total_breakers": { "type": "integer", "minimum": 1 },
        "runtime_mode": { "enum": ["normal", "degraded"] }
      },
      "additionalProperties": true
    },
    "breakers": {
      "type": "array",
      "minItems": 5,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
