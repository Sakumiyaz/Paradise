{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-event-bus-v1.json",
  "title": "EDEN Runtime Event Bus",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "append_only_log",
    "events",
    "message_contract",
    "latest_events"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-event-bus-v1" },
    "artifact": { "const": "runtime_event_bus_state" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "append_only_log": { "type": "string" },
    "events": { "type": "integer", "minimum": 0 },
    "message_contract": { "const": "eden-internal-message-v1" },
    "latest_events": { "type": "array" }
  },
  "additionalProperties": true
}
