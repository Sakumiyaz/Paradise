{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-capability-eval-suite-v1.json",
  "title": "EDEN Capability Eval Suite",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "passed", "total"],
  "properties": {
    "schema": {"const": "eden.capable.capability_eval_suite.v1"},
    "artifact": {"const": "eden_capability_eval_suite"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "passed": {"type": "integer", "minimum": 0},
    "total": {"type": "integer", "minimum": 0}
  }
}
