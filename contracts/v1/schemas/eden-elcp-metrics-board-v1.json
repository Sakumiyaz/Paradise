      "const": "eden.elcp.metrics_board.v1"
    },
    "artifact": {
      "const": "elcp_metrics_board"
    },
    "authority": {
      "const": "global_executive_workspace_core"
    },
    "claim_allowed": {
      "const": false
    },
    "agi_claim": {
      "const": false
    },
    "training_executed": {
      "const": false
    },
    "weights_present": {
      "const": false
    },
    "4b_training_allowed": {
      "const": false
    },
    "metrics": {
      "type": "object"
    },
    "checks": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
