{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eden.elcp.metrics_board.v1",
  "title": "EDEN ELCP Metrics Board",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "claim_allowed",
    "agi_claim",
    "training_executed",
    "weights_present",
    "4b_training_allowed",
    "metrics",
