{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-guard-decision-v1.json",
  "title": "EDEN Runtime Guard Decision",
  "type": "object",
  "required": [
    "schema",
    "id",
    "sequence",
    "timestamp_ms",
    "authority",
    "operation_kind",
    "actor",
    "action",
    "effective_risk",
    "allowed",
    "payload_hash"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-guard-decision-v1" },
    "id": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 1 },
    "timestamp_ms": { "type": "integer", "minimum": 0 },
    "authority": { "const": "global_executive_workspace_core" },
    "operation_kind": { "enum": ["event", "state_mutation"] },
    "actor": { "type": "string" },
    "domain": { "type": "string" },
    "action": { "type": "string" },
    "requested_risk": { "type": "string" },
    "effective_risk": { "enum": ["low", "medium", "high", "forbidden"] },
    "authorized_actor": { "type": "boolean" },
    "active_breakers": { "type": "integer", "minimum": 0 },
    "blocked_by_risk": { "type": "boolean" },
    "blocked_by_breaker": { "type": "boolean" },
    "allowed": { "type": "boolean" },
    "reason": { "type": "string" },
    "payload_hash": { "type": "string" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false }
  },
  "additionalProperties": true
}
