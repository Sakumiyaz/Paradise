{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-spine-verification-v1.json",
  "title": "EDEN Runtime Spine Verification",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "summary",
    "checks",
    "sources",
    "verification_scope"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-spine-verification-v1" },
    "artifact": { "const": "runtime_spine_verification" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "summary": {
      "type": "object",
      "required": ["passed_checks", "total_checks", "verdict"],
      "properties": {
        "passed_checks": { "type": "integer", "minimum": 0 },
        "total_checks": { "type": "integer", "minimum": 1 },
        "verdict": { "enum": ["passed", "needs_attention"] },
        "events": { "type": "integer", "minimum": 0 },
        "state_mutations": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["name", "passed", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "sources": { "type": "object" },
    "verification_scope": {
      "type": "array",
      "minItems": 8,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
