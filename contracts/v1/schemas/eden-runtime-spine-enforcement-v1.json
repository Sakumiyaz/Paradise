{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-spine-enforcement-v1.json",
  "title": "EDEN Runtime Spine Enforcement",
  "type": "object",
  "required": ["schema", "artifact", "authority", "guard_mode", "summary", "guard_flow"],
  "properties": {
    "schema": { "const": "eden-runtime-spine-enforcement-v1" },
    "artifact": { "const": "runtime_spine_enforcement" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "guard_mode": { "const": "mandatory" },
    "summary": { "type": "object" },
    "guard_flow": {
      "type": "array",
      "minItems": 6,
      "items": { "type": "string" }
    },
    "protected_writes": { "type": "object" },
    "authorized_state_writers": { "type": "array" }
  },
  "additionalProperties": true
}
