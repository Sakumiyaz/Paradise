{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-security-gates-v1.json",
  "title": "EDEN Runtime Security Gates",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "coverage",
    "gate_positions",
    "security_self_modification"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-security-gates-v1" },
    "artifact": { "const": "runtime_security_gates" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "coverage": {
      "type": "array",
      "minItems": 10,
      "items": { "type": "string" }
    },
    "gate_positions": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string" }
    },
    "security_self_modification": { "const": "forbidden" }
  },
  "additionalProperties": true
}
