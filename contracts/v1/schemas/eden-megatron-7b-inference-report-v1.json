{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-megatron-7b-inference-report-v1.json",
  "title": "EDEN Megatron 7B Inference Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "authority",
    "claim_allowed",
    "agi_claim",
    "accepted_as",
    "run",
    "responses",
    "safety_boundary"
  ],
  "properties": {
    "schema": {
      "const": "eden.megatron.7b.inference_report.v1"
    },
    "authority": {
      "const": "global_executive_workspace_core"
    },
    "claim_allowed": {
      "const": false
    },
    "agi_claim": {
      "const": false
    },
    "accepted_as": {
      "const": "7b_checkpoint_inference_probe"
    },
    "run": {
      "type": "object",
      "required": [
        "passed",
        "network",
        "external_model_dependency",
        "checkpoint_loaded",
        "checkpoint_admission",
        "production_model",
        "generated_count",
        "tokens_to_generate"
      ],
      "properties": {
        "passed": {
          "const": true
        },
        "network": {
          "const": "none"
        },
        "external_model_dependency": {
          "const": false
        },
        "checkpoint_loaded": {
          "const": true
        },
        "checkpoint_admission": {
          "const": false
        },
        "production_model": {
          "const": false
        },
        "generated_count": {
          "type": "integer",
          "minimum": 1
        },
        "tokens_to_generate": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "prompt",
          "generated_text"
        ],
        "properties": {
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "generated_text": {
            "type": "string",
            "minLength": 1
          },
          "generated_tokens": {
            "type": "array"
          }
        }
      }
    },
    "safety_boundary": {
      "type": "object",
      "required": [
        "direct_memory_writes",
        "direct_objective_writes",
        "direct_tool_execution",
        "requires_gewc_admission",
        "outputs_are_hypotheses"
      ],
      "properties": {
        "direct_memory_writes": {
          "const": false
        },
        "direct_objective_writes": {
          "const": false
        },
        "direct_tool_execution": {
          "const": false
        },
        "requires_gewc_admission": {
          "const": true
        },
        "outputs_are_hypotheses": {
          "const": true
        }
      }
    }
  }
}
