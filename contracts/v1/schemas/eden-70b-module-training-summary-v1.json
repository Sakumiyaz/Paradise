{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-70b-module-training-summary-v1.json",
  "title": "EDEN 70B Module Training Summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "authority",
    "claim_allowed",
    "agi_claim",
    "not_a_single_model",
    "single_dense_70b_training",
    "external_model_dependency",
    "modules",
    "totals"
  ],
  "properties": {
    "schema": { "const": "eden.modular_70b.training_summary.v1" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "not_a_single_model": { "const": true },
    "single_dense_70b_training": { "const": false },
    "external_model_dependency": { "const": false },
    "network_policy": { "const": "docker_network_none" },
    "modules": {
      "type": "object",
      "required": ["trained_on_single_mi300x", "blocked_on_single_mi300x"],
      "properties": {
        "trained_on_single_mi300x": { "type": "array" },
        "blocked_on_single_mi300x": { "type": "array" }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "target_family_parameters",
        "target_parameters_started_on_gpu",
        "observed_parameters_started_on_gpu",
        "modules_started",
        "modules_blocked"
      ],
      "properties": {
        "target_family_parameters": { "type": "integer", "minimum": 1 },
        "target_parameters_started_on_gpu": { "type": "integer", "minimum": 0 },
        "observed_parameters_started_on_gpu": { "type": "integer", "minimum": 0 },
        "modules_started": { "type": "integer", "minimum": 0 },
        "modules_blocked": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
