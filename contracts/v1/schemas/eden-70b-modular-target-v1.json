{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-70b-modular-target-v1.json",
  "title": "EDEN 70B Modular Target",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "artifact",
    "authority",
    "claim_allowed",
    "agi_claim",
    "target_id",
    "architecture_class",
    "not_a_single_model",
    "single_checkpoint_training_allowed",
    "module_count",
    "budget",
    "module_budget",
    "runtime_policy"
  ],
  "properties": {
    "schema": {
      "const": "eden.modular_70b.target.v1"
    },
    "artifact": {
      "const": "eden_70b_modular_target"
    },
    "authority": {
      "const": "global_executive_workspace_core"
    },
    "claim_allowed": {
      "const": false
    },
    "agi_claim": {
      "const": false
    },
    "target_id": {
      "const": "eden-70b-modular-target-v1"
    },
    "architecture_class": {
      "const": "GEWC_COORDINATED_MULTI_MODEL_COGNITIVE_FAMILY"
    },
    "not_a_single_model": {
      "const": true
    },
    "single_checkpoint_training_allowed": {
      "const": false
    },
    "module_count": {
      "const": 6
    },
    "budget": {
      "type": "object",
      "required": [
        "total_parameters",
        "active_default_parameters",
        "single_dense_70b_core_allowed",
        "monolithic_llm_brain_allowed",
        "all_modules_loaded_for_every_request",
        "routed_subset_expected",
        "total_budget_is_family_capacity_not_active_context"
      ],
      "properties": {
        "total_parameters": {
          "const": 70000000000
        },
        "active_default_parameters": {
          "const": 33000000000
        },
        "single_dense_70b_core_allowed": {
          "const": false
        },
        "monolithic_llm_brain_allowed": {
          "const": false
        },
        "all_modules_loaded_for_every_request": {
          "const": false
        },
        "routed_subset_expected": {
          "const": true
        },
        "total_budget_is_family_capacity_not_active_context": {
          "const": true
        }
      }
    },
    "module_budget": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id",
          "role",
          "parameters",
          "authority",
          "routed_by_gewc",
          "single_model_core",
          "direct_tool_execution",
          "direct_memory_write",
          "direct_objective_update"
        ],
        "properties": {
          "parameters": {
            "type": "integer",
            "minimum": 1
          },
          "authority": {
            "const": "global_executive_workspace_core"
          },
          "routed_by_gewc": {
            "const": true
          },
          "single_model_core": {
            "const": false
          },
          "direct_tool_execution": {
            "const": false
          },
          "direct_memory_write": {
            "const": false
          },
          "direct_objective_update": {
            "const": false
          }
        }
      }
    },
    "runtime_policy": {
      "type": "object",
      "required": [
        "gewc_final_authority",
        "models_are_subordinate",
        "outputs_are_hypotheses",
        "direct_memory_writes",
        "direct_objective_writes",
        "direct_tool_execution"
      ],
      "properties": {
        "gewc_final_authority": {
          "const": true
        },
        "models_are_subordinate": {
          "const": true
        },
        "outputs_are_hypotheses": {
          "const": true
        },
        "direct_memory_writes": {
          "const": false
        },
        "direct_objective_writes": {
          "const": false
        },
        "direct_tool_execution": {
          "const": false
        }
      }
    }
  }
}
