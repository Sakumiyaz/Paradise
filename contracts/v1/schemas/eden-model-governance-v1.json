    },
    "authority": {
      "const": "global_executive_workspace_core"
    },
    "claim_allowed": {
      "const": false
    },
    "agi_claim": {
      "const": false
    },
    "governance_principles": {
      "type": "array"
    },
    "permission_matrix": {
      "type": "array"
    },
    "verification": {
      "type": "object"
    },
    "circuit_breakers": {
      "type": "array"
    },
    "safety_boundary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
