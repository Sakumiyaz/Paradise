  "$id": "eden.model_governance.v1",
  "title": "EDEN Model Governance",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "claim_allowed",
    "agi_claim",
    "governance_principles",
    "permission_matrix",
    "verification",
    "circuit_breakers",
    "safety_boundary"
