{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-structured-output-report-v1.json",
  "title": "EDEN Structured Output Report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "packet_count", "parser_contract"],
  "properties": {
    "schema": {"const": "eden.capable.structured_output_report.v1"},
    "artifact": {"const": "eden_structured_output_report"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "packet_count": {"type": "integer", "minimum": 0}
  }
}
