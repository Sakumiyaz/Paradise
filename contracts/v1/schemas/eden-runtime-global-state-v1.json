{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-global-state-v1.json",
  "title": "EDEN Runtime Global State",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "state_model",
    "mutation_log",
    "kernel_heads",
    "locks",
    "rollback"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-global-state-v1" },
    "artifact": { "const": "runtime_global_state" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "state_model": { "const": "append_only_log_plus_validated_snapshot" },
    "mutation_log": { "type": "string" },
    "mutation_count": { "type": "integer", "minimum": 0 },
    "kernel_heads": { "type": "object" },
    "locks": { "type": "object" },
    "rollback": { "type": "object" },
    "latest_mutations": { "type": "array" }
  },
  "additionalProperties": true
}
