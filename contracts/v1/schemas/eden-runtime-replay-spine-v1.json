{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-runtime-replay-spine-v1.json",
  "title": "EDEN Runtime Replay Spine",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "replayable",
    "sources",
    "decision_reconstruction"
  ],
  "properties": {
    "schema": { "const": "eden-runtime-replay-spine-v1" },
    "artifact": { "const": "runtime_replay_spine" },
    "authority": { "const": "global_executive_workspace_core" },
    "claim_allowed": { "const": false },
    "agi_claim": { "const": false },
    "replayable": { "const": true },
    "sources": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string" }
    },
    "decision_reconstruction": {
      "type": "array",
      "minItems": 8,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
