{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-70b-launcher-manifest-v1.json",
  "title": "EDEN 70B Launcher Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "launcher_present", "training_executed", "modules"],
  "properties": {
    "schema": {"const": "eden.modular_70b.launcher_manifest.v1"},
    "artifact": {"const": "eden_70b_launcher_manifest"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "training_executed": {"const": false},
    "modules": {"type": "array", "minItems": 6}
  }
}
