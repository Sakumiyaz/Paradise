{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eden.training_harness.v1",
  "title": "EDEN Training Harness",
  "type": "object",
  "required": [
    "schema",
    "artifact",
    "authority",
    "claim_allowed",
    "agi_claim",
    "training_executed",
    "first_model_trained",
    "phases",
    "safety_boundary"
  ],
  "properties": {
    "schema": {
      "const": "eden.training_harness.v1"
    },
    "artifact": {
      "const": "training_harness_report"
    },
    "authority": {
      "const": "global_executive_workspace_core"
    },
    "claim_allowed": {
      "const": false
    },
    "agi_claim": {
      "const": false
    },
    "training_executed": {
      "const": false
    },
    "first_model_trained": {
      "const": false
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "safety_boundary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
