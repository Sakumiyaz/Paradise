{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eden.local/contracts/v1/schemas/eden-cognitive-dataset-manifest-v1.json",
  "title": "EDEN Cognitive Dataset Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact", "authority", "claim_allowed", "agi_claim", "dataset"],
  "properties": {
    "schema": {"const": "eden.capable.cognitive_dataset_manifest.v1"},
    "artifact": {"const": "eden_cognitive_dataset_manifest"},
    "authority": {"const": "global_executive_workspace_core"},
    "claim_allowed": {"const": false},
    "agi_claim": {"const": false},
    "dataset": {
      "type": "object",
      "required": ["contains_private_data", "records", "valid_records"],
      "properties": {
        "contains_private_data": {"const": false},
        "records": {"type": "integer", "minimum": 0},
        "valid_records": {"type": "integer", "minimum": 0}
      }
    }
  }
}
